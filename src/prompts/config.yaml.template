# =============================================================================
# AI Code Review - Configuration File
# Generated by: ai-review init
#
# Fill in your credentials and preferences below.
# Keep this file private — do NOT commit it to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Configuration
# ---------------------------------------------------------------------------
# Available providers: "openai", "gemini", "claude", "ollama", "azure_openai", "copilot", "bedrock"
llm:
  provider: openai

  # Model to use (empty = provider default)
  # Examples:
  #   openai:  gpt-4o, gpt-4-turbo, gpt-4
  #   gemini:  gemini-1.5-pro, gemini-pro, gemini-2.0-flash
  #   claude:  claude-3-5-sonnet-latest, claude-3-opus-latest, claude-3-haiku-20240307
  #   ollama:  llama3, codellama, mistral, deepseek-coder
  #   copilot: gpt-4o, gpt-4o-mini, o1, o1-mini, claude-3.5-sonnet
  #   bedrock: anthropic.claude-3-5-sonnet-20240620-v1:0, meta.llama3-70b-instruct-v1:0
  model: ""

  # Maximum tokens in response
  max_tokens: 4096

  # Maximum estimated prompt tokens before repository context is trimmed.
  # 0 = provider default; Bedrock defaults to 180000 to stay below hard limits.
  max_prompt_tokens: 0

  # Temperature (0.0 = deterministic, 1.0 = creative)
  temperature: 0.3

# ---------------------------------------------------------------------------
# Provider credentials — fill in the block for your chosen provider
# ---------------------------------------------------------------------------

# openai:
#   api_key: sk-xxxxxxxxxxxxxxxxxxxxxxxx

# gemini:
#   api_key: AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# claude:
#   api_key: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ollama:
#   base_url: http://localhost:11434

# copilot:
#   github_token: ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# bedrock:
#   region: us-east-1
#   profile: default
#   # access_key_id and secret_access_key are optional if using IAM roles or AWS CLI profile
#   access_key_id:
#   secret_access_key:
#   session_token:

# ---------------------------------------------------------------------------
# TFS / Azure DevOps Configuration
# ---------------------------------------------------------------------------
tfs:
  base_url: https://dev.azure.com/your-org   # or https://tfs.company.com/tfs
  collection: DefaultCollection
  project: your-project
  pat: your-personal-access-token
  verify_ssl: true
  # ca_bundle: C:/certs/corporate-root-ca.pem   # optional corporate CA
  # repository:                                  # optional default repo filter

# ---------------------------------------------------------------------------
# Review Preferences
# ---------------------------------------------------------------------------
review:
  # Language: "pt" or "en"
  language: en

  # Default verbosity: "quick", "detailed" or "security"
  verbosity: detailed

  # Review scope:
  #   diff_with_context (default): reviews PR changes with unified diff,
  #     project, and work-item context
  #   diff_only: reviews only differences introduced in the PR
  #   full_code: allows full code review of changed files
  scope: diff_with_context

  # Markdown file with custom rules/context for the prompt
  # The content of this file is injected into LLM instructions on each review
  # custom_prompt_file: review_prompt.md

  # Limit of diff files sent to the LLM (remaining files are omitted)
  max_diff_files: 50

  # Limit of diff lines per file (larger sections are truncated)
  max_diff_lines: 4500

  # Filter by file extensions (empty list = all files)
  # Example: [".py", ".js", ".cs", ".ts"]
  file_extensions_filter: []

  # Repository context sent to the LLM as read-only reference.
  # Review comments are still restricted to modified PR lines.
  project_context:
    enabled: true
    # on_demand = send changed files + manifest, let the model request more files
    # full = send full eligible repository context
    mode: on_demand
    max_files: 0       # full mode only; 0 = include all eligible files
    max_chars: 0       # full mode only; 0 = no character limit
    manifest_max_chars: 60000
    retrieval_max_rounds: 2
    retrieval_max_files: 20
    retrieval_max_chars: 120000
    retrieval_file_max_chars: 30000
    # Empty list = common text/code files. Set an allowlist to narrow context.
    # Example: [".py", ".cs", ".ts", ".yaml"]
    file_extensions: []
    exclude_patterns:
      - .git
      - .hg
      - .svn
      - .venv
      - venv
      - node_modules
      - __pycache__
      - .pytest_cache
      - .mypy_cache
      - .ruff_cache
      - dist
      - build
      - coverage
      - bin
      - obj
      - .env
      - .env.*
      - "*.lock"
      - package-lock.json
      - yarn.lock
      - pnpm-lock.yaml
      - poetry.lock

  # Documentation fields from work items linked to the PR.
  # This is also read-only context; findings still need modified PR lines.
  work_item_context:
    enabled: true
    max_items: 20
    max_chars: 100000
    fields:
      - System.Title
      - System.WorkItemType
      - System.State
      - System.Description
      - Microsoft.VSTS.Common.AcceptanceCriteria
      - Microsoft.VSTS.TCM.ReproSteps
      - Microsoft.VSTS.TCM.SystemInfo

# ---------------------------------------------------------------------------
# Pull Request Review Configuration
# ---------------------------------------------------------------------------
pr:
  # Post comments automatically without confirmation
  auto_post_comments: false

  # Run review without posting comments
  dry_run: false

  # Comment mode: "structured" (inline per file) or "general" (single comment)
  comment_mode: structured

# ---------------------------------------------------------------------------
# Output Configuration
# ---------------------------------------------------------------------------
output:
  # Format: "terminal", "markdown" or "json"
  format: terminal

  # Output file (empty = terminal only)
  file: ""

  # Terminal colors
  color: true

# ---------------------------------------------------------------------------
# Usage Tracking
# ---------------------------------------------------------------------------
usage:
  # Store token usage per reviewed PR in JSON Lines format
  enabled: true
  file: .ai-review-usage.jsonl

  # Optional cost estimation. Prices are per 1M tokens in your billing currency.
  # Keep these values in sync with your provider contract/pricing page.
  # pricing:
  #   openai:
  #     gpt-4o-mini:
  #       input_per_1m: 0.15
  #       output_per_1m: 0.60
  #       currency: USD
